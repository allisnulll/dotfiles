[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = systemd
Target = linux

[Action]
Description = Configure getty auto-login for allisnull
When = PostTransaction
Exec = /bin/sh -c "sed -i 's|^ExecStart=.*|ExecStart=/sbin/agetty -a allisnull - ${TERM}|' /usr/lib/systemd/system/getty@.service"